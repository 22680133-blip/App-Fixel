# ============================================================
# App-Fixel Backend — Variables de Entorno
# Copia este archivo a .env y rellena los valores reales
# NUNCA subas el archivo .env al repositorio
# ============================================================

# Servidor
PORT=3000
NODE_ENV=development

# PostgreSQL (Railway)
# En Railway, usa la variable de referencia: ${{Postgres.DATABASE_URL}}
# Para desarrollo local, usa la URL de tu instancia PostgreSQL local
DATABASE_URL=postgresql://usuario:password@localhost:5432/app-fixel

# JWT
JWT_SECRET=cambia_esto_por_una_cadena_larga_y_aleatoria_en_produccion
JWT_EXPIRES_IN=7d

# Google OAuth (Google Cloud Console)
# Asegúrate de registrar los orígenes autorizados de JavaScript en Google Cloud Console:
#   - http://localhost:8100  (ionic serve)
#   - http://localhost:4200  (ng serve)
#   - http://localhost       (Capacitor)
#   - https://tudominio.com  (producción)
# Si no los registras, verás "Error 400: origin_mismatch"
GOOGLE_CLIENT_ID=509438391464-g46hqas49tl42d8vi3r3oj7pnf7ta09p.apps.googleusercontent.com

# Facebook OAuth (Meta for Developers)
FACEBOOK_APP_ID=1632909734518786
FACEBOOK_APP_SECRET=tu_facebook_app_secret

# ============================================================
# ESP32 / MQTT-TLS — Completa cuando el sensor esté listo
# ============================================================
# URL del broker MQTT con TLS (ej: HiveMQ Cloud, Mosquitto)
MQTT_BROKER_URL=mqtts://tu-broker.com

# Puerto MQTT con TLS (8883 es el estándar)
MQTT_PORT=8883

# Credenciales del broker
MQTT_USERNAME=fixel_server
MQTT_PASSWORD=tu_password_mqtt

# Rutas a los certificados TLS (generados para el broker)
MQTT_CA_CERT_PATH=./certs/ca.crt
MQTT_CLIENT_CERT_PATH=./certs/client.crt
MQTT_CLIENT_KEY_PATH=./certs/client.key

# URL del servidor frontend (para CORS en producción), separados por coma
ALLOWED_ORIGINS=https://tu-app.com,https://www.tu-app.com

# Prefijo de tópicos MQTT
# El ESP32 publica en: fixel/{mqttClientId}/data
# Formato del mensaje JSON: { "temperatura": 3.5, "humedad": 65, "compresor": true, "energia": "Normal" }
MQTT_TOPIC_PREFIX=fixel
